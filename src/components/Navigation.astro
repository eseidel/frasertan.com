---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/recipes/", label: "Recipes" },
  { href: "/curriculum-vitae/", label: "Curriculum Vitae" },
  { href: "/personal-projects/", label: "Personal Projects" },
];
---

<header class="site-header">
  <div class="container">
    <a href="/" class="site-title">FRASER ELISABETH TAN, PHD</a>
    <nav>
      <ul class="site-nav">
        {
          links.map(({ href, label }) => (
            <li>
              <a href={href} class={currentPath === href ? "active" : ""}>
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
